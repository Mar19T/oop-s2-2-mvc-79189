@model IEnumerable<Inspections.Domain.Inspection>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Inspections";
}

<h1>Inspections</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Create New Inspection</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.InspectionDate)</th>
            <th>@Html.DisplayNameFor(model => model.Score)</th>
            <th>@Html.DisplayNameFor(model => model.Outcome)</th>
            <th>@Html.DisplayNameFor(model => model.Notes)</th>
            <th>Premises</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.Outcome == Inspections.Domain.Outcome.Fail ? "table-danger" : "")">
                <td>@item.InspectionDate.ToString("dd MMM yyyy")</td>
                <td>@item.Score</td>
                <td>
                    <span class="badge @(item.Outcome == Inspections.Domain.Outcome.Fail ? "bg-danger" : "bg-success")">
                        @item.Outcome
                    </span>
                </td>
                <td>@item.Notes</td>
                <td>@item.Premises?.Name</td>
                <td>
                    @* Details — everyone can see *@
                    <a asp-action="Details" asp-route-id="@item.Id"
                       class="btn btn-sm btn-info">Details</a>

                    @* Edit — Admin and Inspector only *@
                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">Edit</a>
                    }

                    @* Delete — Admin only *@
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>