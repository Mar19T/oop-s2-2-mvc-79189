@model oop_s2_2_mvc_79189.Models.ErrorViewModel

@{
    ViewData["Title"] = "Something went wrong";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">

            <div class="display-1 text-danger">⚠️</div>
            <h1 class="mt-3">Oops! Something went wrong.</h1>
            <p class="text-muted mt-3">
                @Model.Message
            </p>

            @if (Model.ShowRequestId)
            {
                <p class="text-muted small">
                    Reference ID: <code>@Model.RequestId</code>
                </p>
            }

            <a href="/" class="btn btn-primary mt-3">Go back to Home</a>
        </div>
    </div>
</div>