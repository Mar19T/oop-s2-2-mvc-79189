@model Inspections.Domain.FollowUp
@{
    ViewData["Title"] = "Create Follow-Up";
}

<h1>Create Follow-Up</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="InspectionId" class="control-label"></label>
                <!-- ✅ Shows "Premises Name — Date" instead of Notes -->
                <select asp-for="InspectionId" class="form-control" asp-items="ViewBag.InspectionId">
                    <option value="">-- Select Inspection --</option>
                </select>
                <span asp-validation-for="InspectionId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DueDate" class="control-label"></label>
                <!-- ✅ Pre-filled to 2 weeks from today -->
                <input asp-for="DueDate" class="form-control" type="datetime-local"
                       value="@ViewBag.DefaultDueDate" />
                <small class="text-muted">Suggested: 2 weeks from today</small>
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <!-- ✅ Default to Open since it's a new follow-up -->
                <select asp-for="Status" class="form-control"
                        asp-items="Html.GetEnumSelectList<Inspections.Domain.FollowUpStatus>()">
                    <option value="">-- Select Status --</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <!-- ✅ ClosedDate removed from Create — only shown in Edit -->

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}