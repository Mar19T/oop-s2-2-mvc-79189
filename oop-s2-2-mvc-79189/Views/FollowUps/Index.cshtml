@model IEnumerable<Inspections.Domain.FollowUp>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Follow-Ups";
}

<h1>Follow-Ups</h1>

@* Create — Admin and Inspector *@
@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Create New Follow-Up</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.DueDate)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.ClosedDate)</th>
            <th>Inspection Notes</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var isOverdue = item.Status == Inspections.Domain.FollowUpStatus.Open
            && item.DueDate < DateTime.Today;
            <tr class="@(isOverdue ? "table-danger" : "")">
                <td>
                    @item.DueDate.ToString("dd MMM yyyy")
                    @if (isOverdue)
                    {
                        <span class="badge bg-danger ms-1">Overdue</span>
                    }
                </td>
                <td>
                    <span class="badge @(item.Status == Inspections.Domain.FollowUpStatus.Open ? "bg-warning" : "bg-success")">
                        @item.Status
                    </span>
                </td>
                <td>
                    @(item.ClosedDate.HasValue? item.ClosedDate.Value.ToString("dd MMM yyyy") : "-")
                </td>
                <td>@item.Inspection?.Notes</td>
                <td>
                    @* Details — everyone *@
                    <a asp-action="Details" asp-route-id="@item.Id"
                       class="btn btn-sm btn-info">Details</a>

                    @* Edit — Admin and Inspector *@
                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">Edit</a>
                    }

                    @* Delete — Admin only *@
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>