@model IEnumerable<Inspections.Domain.Premises>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Premises";
}

<h1>Premises</h1>

@* Create — Admin only for Premises *@
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Create New Premises</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Address)</th>
            <th>@Html.DisplayNameFor(model => model.Town)</th>
            <th>@Html.DisplayNameFor(model => model.RiskRating)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Address</td>
                <td>@item.Town</td>
                <td>
                    <span class="badge
                            @(item.RiskRating == Inspections.Domain.RiskRating.High ? "bg-danger" :
                                                    item.RiskRating == Inspections.Domain.RiskRating.Medium ? "bg-warning" :
                                                    "bg-success")">
                    @item.RiskRating
                </span>
            </td>
            <td>
                @* Details — everyone *@
                <a asp-action="Details" asp-route-id="@item.Id"
                   class="btn btn-sm btn-info">Details</a>

                    @* Edit — Admin only *@
                @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">Edit</a>
                    }

                    @* Delete — Admin only *@
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>