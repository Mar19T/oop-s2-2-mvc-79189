<h1>Dashboard</h1>

<div style="display:flex; gap:20px;">

    <div style="background:#d4edda; padding:20px;">
        <h3>Total Inspections</h3>
        <p>@ViewBag.Total</p>
    </div>

    <div style="background:#f8d7da; padding:20px;">
        <h3>Failed Inspections</h3>
        <p>@ViewBag.Failed</p>
    </div>

    <div style="background:#fff3cd; padding:20px;">
        <h3>Overdue FollowUps</h3>
        <p>@ViewBag.Overdue</p>
    </div>

</div>